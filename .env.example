# service-depot — secrets + config. Copy to .env (GITIGNORED) and fill in, or run `depot setup` to
# generate the secrets for you. NEVER commit the real .env.
#
# ⚠️  This file is committed — keep it GENERIC. Real secrets/keys live ONLY in the gitignored .env.

# ---- Core Langfuse secrets (generate strong values; `depot setup` does this). ----
#   openssl rand -hex 32   → ENCRYPTION_KEY
#   openssl rand -base64 32 → NEXTAUTH_SECRET / SALT
NEXTAUTH_SECRET=<changeme>
SALT=<changeme>
ENCRYPTION_KEY=<changeme-64-hex>
NEXTAUTH_URL=http://localhost:3000

# ---- Backing-store credentials. ----
POSTGRES_PASSWORD=<changeme>
CLICKHOUSE_PASSWORD=<changeme>
REDIS_AUTH=<changeme>
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=<changeme>

# ---- Telemetry: OFF (the server egress allowlist blocks the phone-home anyway). ----
TELEMETRY_ENABLED=false

# ---- Headless bootstrap of the org + the stage-2 project + admin user on first boot. ----
#   These create the FIRST project deterministically so `depot connect stage-2` can print its keys.
#   Additional projects (e.g. stage-3) are created later in the Langfuse UI.
LANGFUSE_INIT_ORG_ID=depot
LANGFUSE_INIT_ORG_NAME=depot
LANGFUSE_INIT_PROJECT_ID=stage-2-research
LANGFUSE_INIT_PROJECT_NAME=stage-2-research
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-<changeme>
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-<changeme>
LANGFUSE_INIT_USER_EMAIL=<you@example.com>
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=<changeme>

# ---- Per-consumer connection keys (what `depot connect <app>` prints). ----
#   stage-2 reuses the init keys above; record stage-3's keys here once created in the UI.
# STAGE3_LANGFUSE_PUBLIC_KEY=pk-lf-...
# STAGE3_LANGFUSE_SECRET_KEY=sk-lf-...

# ---- Optional: relocate the stateful data off Docker's default data-root (must be LOCAL disk). ----
# DEPOT_DATA_DIR=/var/lib/depot
